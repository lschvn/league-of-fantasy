    {
      "name": "02 Auth",
      "item": [
        {
          "name": "POST /register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "description": "Creates a new API user for the join flows. The password must satisfy the Laravel validation policy used by the app.",
            "url": "{{baseUrl}}/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{newUserName}}\",\n  \"email\": \"{{newUserEmail}}\",\n  \"password\": \"{{newUserPassword}}\",\n  \"password_confirmation\": \"{{newUserPassword}}\",\n  \"device_name\": \"postman-register\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now().toString();",
                  "pm.collectionVariables.set(\"newUserName\", `API Test User ${suffix}`);",
                  "pm.collectionVariables.set(\"newUserEmail\", `api-test-${suffix}@fantasy.test`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set(\"newUserToken\", response.data.token);",
                  "pm.collectionVariables.set(\"newUserEmail\", response.data.user.email);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /login owner",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "description": "Logs in the public league owner.",
            "url": "{{baseUrl}}/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\",\n  \"device_name\": \"postman-owner\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set(\"ownerToken\", response.data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /login eve",
          "request": {
