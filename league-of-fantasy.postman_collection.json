  "item": [
    {
      "name": "01 Public Discovery",
      "item": [
        {
          "name": "GET /competitions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "description": "Lists competitions and confirms the seeded demo competition exists.",
            "url": "{{baseUrl}}/competitions"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const response = pm.response.json();",
                  "if (response.data && response.data[0]) {",
                  "  pm.collectionVariables.set(\"competitionId\", String(response.data[0].id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /competitions/:competition",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "description": "Shows the seeded competition with teams and weeks.",
            "url": "{{baseUrl}}/competitions/{{competitionId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /competitions/:competition/weeks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "description": "Captures week 1 and week 2 IDs from the seeded competition.",
            "url": "{{baseUrl}}/competitions/{{competitionId}}/weeks"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const response = pm.response.json();",
                  "const week1 = response.data.find((week) => week.number === 1);",
                  "const week2 = response.data.find((week) => week.number === 2);",
                  "if (week1) pm.collectionVariables.set(\"week1Id\", String(week1.id));",
                  "if (week2) pm.collectionVariables.set(\"week2Id\", String(week2.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /weeks/:week/matches",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "description": "Reads week 1 matches and captures the first match ID for downstream requests.",
            "url": "{{baseUrl}}/weeks/{{week1Id}}/matches"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const response = pm.response.json();",
                  "if (response.data && response.data[0]) {",
                  "  pm.collectionVariables.set(\"matchId\", String(response.data[0].id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /matches/:match",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "description": "Shows the selected match.",
            "url": "{{baseUrl}}/matches/{{matchId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /matches/:match/player-stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "description": "Reads player stats and captures a valid player ID for the auction bid request.",
            "url": "{{baseUrl}}/matches/{{matchId}}/player-stats"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
