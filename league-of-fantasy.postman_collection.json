            }
          ]
        },
        {
          "name": "GET /fantasy-leagues",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "description": "Lists public fantasy leagues and captures the seeded Review League ID.",
            "url": "{{baseUrl}}/fantasy-leagues"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const response = pm.response.json();",
                  "const reviewLeague = response.data.find((league) => league.name === \"Review League\");",
                  "if (reviewLeague) {",
                  "  pm.collectionVariables.set(\"publicLeagueId\", String(reviewLeague.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /fantasy-leagues/:fantasyLeague",
          "request": {
            "method": "GET",
            "header": [
