          ]
        },
        {
          "name": "GET /me owner",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ownerToken}}",
                "type": "text"
              }
            ],
            "description": "Loads the owner membership and captures the Review League fantasy team ID.",
            "url": "{{baseUrl}}/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const response = pm.response.json();",
                  "const membership = response.data.memberships.find((entry) => String(entry.fantasy_league_id) === pm.collectionVariables.get(\"publicLeagueId\"));",
                  "if (membership && membership.fantasy_team) {",
                  "  pm.collectionVariables.set(\"ownerTeamId\", String(membership.fantasy_team.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /me eve",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{eveToken}}",
                "type": "text"
              }
            ],
            "description": "Loads the private league owner membership and captures the private league and team IDs.",
            "url": "{{baseUrl}}/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const response = pm.response.json();",
                  "const membership = response.data.memberships[0];",
                  "if (membership) {",
                  "  pm.collectionVariables.set(\"privateLeagueId\", String(membership.fantasy_league_id));",
                  "  pm.collectionVariables.set(\"eveTeamId\", String(membership.fantasy_team.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /me farah",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{farahToken}}",
                "type": "text"
              }
            ],
            "description": "Loads Farah’s fantasy team ID for the roster management step.",
            "url": "{{baseUrl}}/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const response = pm.response.json();",
                  "const membership = response.data.memberships[0];",
                  "if (membership && membership.fantasy_team) {",
                  "  pm.collectionVariables.set(\"farahTeamId\", String(membership.fantasy_team.id));",
                  "}"
                ]
              }
            }
          ]
        }
