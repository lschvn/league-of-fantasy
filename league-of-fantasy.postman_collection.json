        {
          "name": "GET /fantasy-teams/:team/roster owner",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ownerToken}}",
                "type": "text"
              }
            ],
            "description": "Reads the owner roster and captures the slot IDs needed for the week 2 lineup submission.",
            "url": "{{baseUrl}}/fantasy-teams/{{ownerTeamId}}/roster"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const response = pm.response.json();",
                  "const active = response.data.filter((entry) => entry.status === \"active\");",
                  "const pick = (role, index) => active.filter((entry) => entry.player.role === role)[index];",
                  "const top1 = pick(\"TOP\", 0);",
                  "const top2 = pick(\"TOP\", 1);",
                  "const jgl = pick(\"JGL\", 0);",
                  "const mid1 = pick(\"MID\", 0);",
                  "const mid2 = pick(\"MID\", 1);",
                  "const adc = pick(\"ADC\", 0);",
                  "const sup = pick(\"SUP\", 0);",
                  "if (top1) pm.collectionVariables.set(\"ownerTopSlotId\", String(top1.id));",
                  "if (top2) pm.collectionVariables.set(\"ownerFlexTopSlotId\", String(top2.id));",
                  "if (jgl) pm.collectionVariables.set(\"ownerJglSlotId\", String(jgl.id));",
                  "if (mid1) pm.collectionVariables.set(\"ownerMidCaptainSlotId\", String(mid1.id));",
                  "if (mid2) pm.collectionVariables.set(\"ownerFlexMidSlotId\", String(mid2.id));",
                  "if (adc) pm.collectionVariables.set(\"ownerAdcSlotId\", String(adc.id));",
                  "if (sup) pm.collectionVariables.set(\"ownerSupSlotId\", String(sup.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /fantasy-teams/:team/lineups",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{ownerToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "description": "Submits a valid week 2 lineup using the captured owner roster slot IDs.",
            "url": "{{baseUrl}}/fantasy-teams/{{ownerTeamId}}/lineups",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"week_id\": \"{{week2Id}}\",\n  \"slots\": [\n    {\n      \"roster_slot_id\": \"{{ownerTopSlotId}}\",\n      \"position\": \"TOP\",\n      \"is_captain\": false\n    },\n    {\n      \"roster_slot_id\": \"{{ownerJglSlotId}}\",\n      \"position\": \"JGL\",\n      \"is_captain\": false\n    },\n    {\n      \"roster_slot_id\": \"{{ownerMidCaptainSlotId}}\",\n      \"position\": \"MID\",\n      \"is_captain\": true\n    },\n    {\n      \"roster_slot_id\": \"{{ownerAdcSlotId}}\",\n      \"position\": \"ADC\",\n      \"is_captain\": false\n    },\n    {\n      \"roster_slot_id\": \"{{ownerSupSlotId}}\",\n      \"position\": \"SUP\",\n      \"is_captain\": false\n    },\n    {\n      \"roster_slot_id\": \"{{ownerFlexTopSlotId}}\",\n      \"position\": \"FLEX_1\",\n      \"is_captain\": false\n    },\n    {\n      \"roster_slot_id\": \"{{ownerFlexMidSlotId}}\",\n      \"position\": \"FLEX_2\",\n      \"is_captain\": false\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
